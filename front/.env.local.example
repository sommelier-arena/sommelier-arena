# Environment variables for local development (Mode A — PartyKit dev server)
# Copy this file to .env.local and fill in the value for your setup.
#
# ── Mode A: Local dev (Astro dev server + PartyKit dev server) ───────────────
# PartyKit runs on port 1999. Connect directly — no proxy needed.
PUBLIC_PARTYKIT_HOST=localhost:1999

# ── Mode B: Docker (docker-compose up) ───────────────────────────
# Do NOT create .env.local for Docker mode. PUBLIC_PARTYKIT_HOST=localhost:4321
# is injected as a Docker build arg in docker-compose.yml. Creating .env.local
# here would be ignored at Docker build time anyway.

# ── Production (Cloudflare Pages) ────────────────────────────────────────────
# Set PUBLIC_PARTYKIT_HOST in the Cloudflare Pages dashboard:
#   Pages → Project → Settings → Environment variables
#   PUBLIC_PARTYKIT_HOST=your-partykit-project.partykit.dev
