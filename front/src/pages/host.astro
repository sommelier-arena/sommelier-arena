---
import { HostApp } from '../components/host/HostApp';
import { NavBar } from '../components/common/NavBar';
import Footer from '../components/common/Footer.astro';
import PageHead from '../components/common/PageHead.astro';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <PageHead title="Host — Sommelier Arena" description="Create and manage a live wine tasting quiz session." />
  </head>
  <body class="bg-slate-50 min-h-screen flex flex-col">
    <NavBar client:only="react" />
    <main class="flex-1 min-h-0 overflow-auto">
      <HostApp client:only="react" showNav={false}>
        <div slot="fallback" class="flex items-center justify-center h-40 text-slate-400">
          Loading…
        </div>
      </HostApp>
    </main>
    <Footer />
  </body>
</html>
