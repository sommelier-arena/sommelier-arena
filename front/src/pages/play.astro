---
import { ParticipantApp } from '../components/participant/ParticipantApp';
import { NavBar } from '../components/common/NavBar';
import Footer from '../components/common/Footer.astro';
import PageHead from '../components/common/PageHead.astro';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <PageHead title="Play — Sommelier Arena" description="Join a live blind wine tasting quiz session." />
  </head>
  <body class="bg-slate-50 min-h-screen flex flex-col">
    <NavBar client:only="react" />
    <main class="flex-1 min-h-0 overflow-auto">
      <ParticipantApp client:only="react" showNav={false}>
        <div slot="fallback" class="flex items-center justify-center h-40 text-slate-400">
          Loading…
        </div>
      </ParticipantApp>
    </main>
    <Footer />
  </body>
</html>
