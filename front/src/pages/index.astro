<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sommelier Arena</title>
  </head>
  <body class="bg-slate-50 min-h-screen flex items-center justify-center px-4">
    <main class="text-center space-y-8 max-w-sm w-full">
      <div>
        <p class="text-6xl mb-4">🍷</p>
        <h1 class="text-4xl font-bold text-slate-800">Sommelier Arena</h1>
        <p class="text-slate-500 mt-2">A real-time blind wine tasting quiz.</p>
      </div>

      <div class="flex flex-col gap-4">
        <a
          href="/host"
          class="block w-full bg-violet-600 text-white rounded-xl py-4 font-semibold text-lg hover:bg-violet-700 transition-colors text-center"
        >
          I'm the Host
        </a>
        <a
          href="/play"
          class="block w-full border border-violet-300 text-violet-600 rounded-xl py-4 font-semibold text-lg hover:bg-violet-50 transition-colors text-center"
        >
          Join as Participant
        </a>
      </div>

      <p class="text-slate-400 text-sm">
        No account needed. Pick a role and start tasting!
      </p>
    </main>
  </body>
</html>
